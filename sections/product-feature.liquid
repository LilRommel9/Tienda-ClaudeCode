{% comment %}
  Product Feature – muestra una imagen de producto, precio y CTA.
  Usa el placeholder SVG que creamos; reemplázalo con tu foto real.
{% endcomment %}

{% schema %}
{
  "name": "Product Feature",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagen del producto"
    },
    {
      "type": "text",
      "id": "product_name",
      "label": "Nombre del producto",
      "default": "Producto Premium para Adultos Mayores"
    },
    {
      "type": "richtext",
      "id": "product_description",
      "label": "Descripción corta",
      "default": "<p>Diseñado para mayor comodidad y seguridad. Fácil de usar, con garantía de 30 días.</p>"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Precio",
      "default": "$129.99"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Añadir al carrito"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Enlace del botón",
      "default": "https://u7ns0n-hx.myshopify.com/cart"
    }
  ],
  "presets": [{ "name": "Product Feature", "category": "Feature" }]
}
{% endschema %}

<section class="product-feature" style="display:flex;flex-direction:column;align-items:center;padding:2rem;background:#fafafa;">
  <img src="{{ section.settings.product_image | img_url: '800x800' }}" alt="{{ section.settings.product_name }}" style="max-width:400px;width:100%;margin-bottom:1rem;" />
  <h2 style="font-size:2rem;color:#2E2A39;margin:0;">{{ section.settings.product_name }}</h2>
  {{ section.settings.product_description | raw }}
  <p style="font-size:1.75rem;color:#6D388B;margin:0.5rem 0;">{{ section.settings.price }}</p>
  <a href="{{ section.settings.button_url }}" class="btn-primary" style="background:#6D388B;color:#fff;padding:.8rem 1.5rem;border-radius:6px;font-size:1.125rem;text-decoration:none;">
    {{ section.settings.button_label }}
  </a>
</section>

<style>
  .product-feature .btn-primary:hover { background:#5a2f73; }
</style>
