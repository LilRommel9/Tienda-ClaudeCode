<footer class="site-footer section-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 3rem; margin-bottom: 3rem;">
      
      <!-- Brand Column -->
      <div class="footer-brand">
        <div style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 600; color: var(--text-main); margin-bottom: 1rem;">
          {{ shop.name }}
        </div>
        <p style="color: var(--text-muted); line-height: 1.6; margin-bottom: 1.5rem;">
          {{ section.settings.about_text }}
        </p>
        <div style="display: flex; gap: 1rem;">
          {% if settings.instagram_url != blank %}
            <a href="{{ settings.instagram_url }}" style="color: var(--primary); font-size: 1.25rem;"><i class="fab fa-instagram"></i></a>
          {% endif %}
          {% if settings.facebook_url != blank %}
            <a href="{{ settings.facebook_url }}" style="color: var(--primary); font-size: 1.25rem;"><i class="fab fa-facebook-f"></i></a>
          {% endif %}
          {% if settings.whatsapp_number != blank %}
            <a href="https://wa.me/{{ settings.whatsapp_number }}" style="color: var(--primary); font-size: 1.25rem;"><i class="fab fa-whatsapp"></i></a>
          {% endif %}
        </div>
      </div>

      <!-- Links Column 1 -->
      <div class="footer-column">
        <h4 style="font-size: 1.1rem; margin-bottom: 1.5rem;">{{ section.settings.menu_title_1 }}</h4>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          {% for link in linklists[section.settings.menu_1].links %}
            <a href="{{ link.url }}" style="color: var(--text-muted); font-size: 0.95rem;">{{ link.title }}</a>
          {% else %}
            <a href="/collections/all" style="color: var(--text-muted); font-size: 0.95rem;">Tienda</a>
            <a href="/pages/about" style="color: var(--text-muted); font-size: 0.95rem;">Nosotros</a>
          {% endfor %}
        </div>
      </div>

      <!-- Links Column 2 -->
      <div class="footer-column">
        <h4 style="font-size: 1.1rem; margin-bottom: 1.5rem;">{{ section.settings.menu_title_2 }}</h4>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          {% for link in linklists[section.settings.menu_2].links %}
            <a href="{{ link.url }}" style="color: var(--text-muted); font-size: 0.95rem;">{{ link.title }}</a>
          {% else %}
            <a href="/pages/contact" style="color: var(--text-muted); font-size: 0.95rem;">Contacto</a>
            <a href="/pages/faq" style="color: var(--text-muted); font-size: 0.95rem;">Preguntas Frecuentes</a>
          {% endfor %}
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div style="border-top: 1px solid var(--light-border); padding-top: 2rem; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem;">
      <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0;">
        &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. Todos los derechos reservados.
      </p>
      <div style="display: flex; gap: 1.5rem;">
        <a href="/pages/privacy" style="color: var(--text-muted); font-size: 0.85rem;">Privacidad</a>
        <a href="/pages/terms" style="color: var(--text-muted); font-size: 0.85rem;">Términos</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#faf9f6"
    },
    {
      "type": "textarea",
      "id": "about_text",
      "label": "Texto de Nosotros",
      "default": "Creando momentos de confort y estilo en casa con nuestra colección premium de loungewear."
    },
    {
      "type": "text",
      "id": "menu_title_1",
      "label": "Título Menú 1",
      "default": "Explorar"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menú 1"
    },
    {
      "type": "text",
      "id": "menu_title_2",
      "label": "Título Menú 2",
      "default": "Ayuda"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menú 2"
    }
  ]
}
{% endschema %}
