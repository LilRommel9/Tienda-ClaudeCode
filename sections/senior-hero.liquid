{% comment %}
  Senior Hero – versión accesible para adultos mayores.
  Uso: Añadir a index.json como primer bloque.
{% endcomment %}

{% schema %}
{
  "name": "Senior Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Imagen de fondo (adulto mayor feliz)"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Título principal",
      "default": "<h1>Tranquilidad para tus seres queridos</h1>"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "<p>Productos seguros y fáciles de usar para una vida más cómoda</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Comprar ahora"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Enlace del botón",
      "default": "/collections/all"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Mostrar badge de garantía",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texto del badge",
      "default": "30 días de garantía"
    }
  ],
  "presets": [{ "name": "Senior Hero", "category": "Hero" }]
}
{% endschema %}

{%- if section.settings.hero_image != blank -%}
  {%- assign hero_bg_url = section.settings.hero_image | img_url: '1200x800' -%}
{%- else -%}
  {%- assign hero_bg_url = 'senior-hero-banner.svg' | asset_url -%}
{%- endif -%}

<section class="senior-hero" style="background:url({{ hero_bg_url }}) center/cover no-repeat;">
  <div class="overlay" style="background:rgba(255,255,255,0.85);padding:3rem;max-width:800px;margin:auto;text-align:center;">
    {{ section.settings.title | raw }}
    {{ section.settings.subtitle | raw }}
    {% if section.settings.show_badge %}
      <span class="badge" style="background:#6D388B;color:#fff;padding:.3rem .6rem;border-radius:4px;display:inline-block;margin:0.5rem 0;">
        {{ section.settings.badge_text }}
      </span>
    {% endif %}
    <a href="{{ section.settings.button_url }}" class="btn-primary" style="margin-top:1rem;background:#6D388B;color:#fff;padding:.8rem 1.5rem;border-radius:6px;font-size:1.125rem;display:inline-block;">
      {{ section.settings.button_label }}
    </a>
  </div>
</section>

<style>
  .senior-hero .btn-primary:hover { background:#5a2f73; }
</style>
