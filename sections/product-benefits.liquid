<section class="product-benefits section-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="container" style="text-align: center;">
    {% if section.settings.eyebrow != blank %}
      <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    
    {% if section.settings.title != blank %}
      <h2 style="margin-bottom: 3rem;">{{ section.settings.title }}</h2>
    {% endif %}
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
      {% for block in section.blocks %}
        <div class="benefit-card" style="padding: 2.5rem 1.5rem; background: var(--white); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); transition: transform 0.3s ease;">
          <div style="font-size: 2.5rem; color: var(--primary); margin-bottom: 1.5rem;">
            {% case block.settings.icon %}
              {% when 'cloud' %}
                <i class="fas fa-cloud"></i>
              {% when 'heart' %}
                <i class="fas fa-heart"></i>
              {% when 'moon' %}
                <i class="fas fa-moon"></i>
              {% when 'star' %}
                <i class="fas fa-star"></i>
              {% when 'leaf' %}
                <i class="fas fa-leaf"></i>
            {% endcase %}
          </div>
          <h3 style="font-size: 1.25rem; font-weight: 600;">{{ block.settings.title }}</h3>
          <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .benefit-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }
</style>

{% schema %}
{
  "name": "Beneficios del Producto",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#faf9f6"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto Superior",
      "default": "Por qué amarlo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título Principal",
      "default": "Confort sin compromisos"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "cloud", "label": "Nube (Suavidad)" },
            { "value": "heart", "label": "Corazón (Amor)" },
            { "value": "moon", "label": "Luna (Descanso)" },
            { "value": "star", "label": "Estrella (Calidad)" },
            { "value": "leaf", "label": "Hoja (Ligero)" }
          ],
          "default": "cloud"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Terciopelo Premium"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción",
          "default": "Material extrasuave que abraza tu piel para un descanso perfecto."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Beneficios del Producto",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "cloud", "title": "Suavidad Extrema", "text": "Terciopelo de alta calidad que no irrita la piel." } },
        { "type": "benefit", "settings": { "icon": "heart", "title": "Diseño Femenino", "text": "Crop top y shorts ajustables que realzan tu figura." } },
        { "type": "benefit", "settings": { "icon": "moon", "title": "Dormir o Estar", "text": "Perfecto tanto para dormir como para hacer maratón de series." } }
      ]
    }
  ]
}
{% endschema %}
