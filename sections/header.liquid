<header class="site-header" id="site-header" style="background-color: {{ section.settings.bg_color }};">
  <div class="header-inner" style="display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; padding: 1rem 1.5rem;">
    <!-- Logo -->
    <a href="{{ shop.url }}" class="header-logo" style="text-decoration: none;">
      {%- if section.settings.logo -%}
        <img src="{{ section.settings.logo | img_url: '150x' }}" alt="{{ shop.name }}" style="height: {{ section.settings.logo_height }}px; width: auto;">
      {%- else -%}
        <span style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 600; color: var(--text-main);">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <!-- Navigation -->
    <nav class="header-nav" id="desktop-nav" style="display: flex; gap: 2rem;">
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}" style="font-size: 1rem; color: var(--text-main); text-decoration: none; font-weight: 500;">
          {{ link.title }}
        </a>
      {% else %}
        <a href="{{ shop.url }}" style="font-size: 1rem; color: var(--text-main); text-decoration: none; font-weight: 500;">Inicio</a>
        <a href="/collections/all" style="font-size: 1rem; color: var(--text-main); text-decoration: none; font-weight: 500;">Colecciones</a>
        <a href="/pages/about" style="font-size: 1rem; color: var(--text-main); text-decoration: none; font-weight: 500;">Nosotros</a>
        <a href="/pages/contact" style="font-size: 1rem; color: var(--text-main); text-decoration: none; font-weight: 500;">Contacto</a>
      {% endfor %}
    </nav>

    <!-- Actions -->
    <div class="header-actions" style="display: flex; align-items: center; gap: 1.5rem;">
      <a href="/cart" class="header-cart" aria-label="Carrito de compras" style="position: relative; color: var(--text-main); font-size: 1.25rem;">
        <i class="fas fa-shopping-bag"></i>
        {%- if cart.item_count > 0 -%}
          <span style="position: absolute; top: -8px; right: -10px; background: var(--primary); color: white; font-size: 0.625rem; font-weight: 700; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            {{ cart.item_count }}
          </span>
        {%- endif -%}
      </a>

      <!-- Mobile Menu Toggle -->
      <button class="menu-toggle" id="menu-toggle" aria-label="Abrir menú" style="display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer;">
        <span style="width: 25px; height: 2px; background: var(--text-main);"></span>
        <span style="width: 25px; height: 2px; background: var(--text-main);"></span>
        <span style="width: 25px; height: 2px; background: var(--text-main);"></span>
      </button>
    </div>
  </div>
</header>

<style>
  @media (max-width: 768px) {
    #desktop-nav { display: none !important; }
    #menu-toggle { display: flex !important; }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#faf9f6"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Imagen del Logo"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Altura del Logo (px)",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú de Navegación"
    }
  ]
}
{% endschema %}
