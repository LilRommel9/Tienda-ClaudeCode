// ========================================
// Funcionalidad interactiva para la tienda
// ========================================

document.addEventListener('DOMContentLoaded', function() {
    // Cart functionality
    window.cartItemsCount = 0;
    window.addedItems = {};

    // Initialize cart count from cookie or localStorage if needed
    updateCartDisplay();

    // WhatsApp floating button functionality
    initWhatsAppFloat();

    // Mobile menu functionality
    initMobileMenu();

    // Smooth scroll for anchor links
    initSmoothScroll();

    // Newsletter form submission
    initNewsletterForm();

    // Product filter functionality (if on collection page)
    initProductFilters();
});

// Cart Functions
function addToCart(productName, price, imgUrl) {
    cartItemsCount += 1;
    addedItems[productName] = (addedItems[productName] || 0) + 1;

    // Update cart display
    updateCartDisplay();

    // Generate WhatsApp checkout text pre-fill
    const waText = encodeURIComponent(`¡Hola LostGenClub! Me interesa concretar la compra del brazalete ${productName} por MXN$${price.toLocaleString()}. Quedo a la espera de sus datos.`);
    const waUrl = `https://wa.me/${shopifyConfig.whatsappNumber}?text=${waText}`;

    // Show toast notification
    showToast(
        '¡Brazalete Agregado!',
        `Has agregado <strong>${productName}</strong> al carrito de compra.`,
        'Finalizar por WhatsApp',
        `window.open('${waUrl}', '_blank')`,
        'Seguir comprando',
        ''
    );
}

function openCartPreview() {
    if (cartItemsCount === 0) {
        showToast('Carrito Vacío', 'Explora nuestros brazaletes y añade tus favoritos para iniciar tu orden.', '', '', 'Entendido', '');
        return;
    }

    let itemsList = '';
    for (const [name, qty] of Object.entries(addedItems)) {
        if (qty > 0) {
            itemsList += `• ${name} (x${qty})<br>`;
        }
    }

    const checkoutText = encodeURIComponent(`Hola LostGenClub! Quisiera comprar los siguientes brazaletes:\n${Object.entries(addedItems).map(([name, qty]) => `${name} (x${qty})`).join('\n')}\n¿Me podrían guiar con el pago y envío?`);
    const checkoutUrl = `https://wa.me/${shopifyConfig.whatsappNumber}?text=${checkoutText}`;

    showToast(
        'Resumen de Orden',
        `<strong>Tus artículos:</strong><br>${itemsList}`,
        'Finalizar Compra',
        `window.open('${checkoutUrl}', '_blank')`,
        'Vaciar Carrito',
        'resetCart()'
    );
}

function updateCartDisplay() {
    const cartBadge = document.getElementById('cartBadge');
    if (cartBadge) {
        cartBadge.textContent = cartItemsCount;
    }
}

function resetCart() {
    cartItemsCount = 0;
    document.getElementById('cartBadge').textContent = 0;
    for (const key in addedItems) {
        delete addedItems[key];
    }
    showToast('Carrito Vaciado', 'El carrito ha sido vaciado.', '', '', 'Cerrar', '');
}

// WhatsApp Floating Button
function initWhatsAppFloat() {
    const whatsappFloat = document.querySelector('.whatsapp-float');
    if (whatsappFloat) {
        // Add pulse animation
        whatsappFloat.innerHTML = `
            <a href="https://wa.me/${shopifyConfig.whatsappNumber}?text=Hola%20!%20Quisiera%20m%C3%A1s%20informaci%C3%B3n%20sobre%20sus%20productos." class="whatsapp-link" target="_blank" rel="noopener noreferrer">
                <i class="fab fa-whatsapp"></i>
            </a>
        `;

        // Add badge if there are items in cart
        if (cartItemsCount > 0) {
            const badge = document.createElement('div');
            badge.className = 'whatsapp-badge';
            badge.textContent = cartItemsCount;
            whatsappFloat.appendChild(badge);
        }
    }
}

// Mobile Menu
function initMobileMenu() {
    const menuBtn = document.querySelector('.menu-btn');
    const mobileMenu = document.getElementById('mobileMenu');

    if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', toggleMenu);

        // Close mobile menu when clicking a link
        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.remove('active');
            });
        });
    }
}

function toggleMenu() {
    const menu = document.getElementById('mobileMenu');
    if (menu) {
        menu.classList.toggle('active');
    }
}

// Smooth Scroll
function initSmoothScroll() {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        });
    });
}

// Newsletter Form
function initNewsletterForm() {
    const form = document.querySelector('.newsletter-form');
    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            const emailInput = document.getElementById('newsletterEmail');
            const email = emailInput.value.trim();

            if (email) {
                // Here you would integrate with your email service (Mailchimp, Klaviyo, etc.)
                showToast(
                    '¡Bienvenido al Imperio!',
                    `Te has suscrito con <strong>${email}</strong>. Te enviaremos accesos anticipados y promociones VIP de inmediato.`,
                    '', '', '¡Excelente!', ''
                );
                emailInput.value = '';
            }
        });
    }
}

// Product Filters (for collection pages)
function initProductFilters() {
    const filterButtons = document.querySelectorAll('.collection-tab');
    if (filterButtons.length > 0) {
        filterButtons.forEach(button => {
            button.addEventListener('click', function() {
                // Remove active class from all buttons
                filterButtons.forEach(btn => btn.classList.remove('active'));

                // Add active class to clicked button
                this.classList.add('active');

                // Get filter category
                const category = this.getAttribute('data-category');

                // Filter products
                const products = document.querySelectorAll('.product-card');
                products.forEach(product => {
                    if (category === 'all' || product.getAttribute('data-category') === category) {
                        product.style.display = 'block';
                    } else {
                        product.style.display = 'none';
                    }
                });
            });
        });
    }
}

// Toast Notification System
function showToast(title, message, primaryBtnText, primaryBtnAction, secondaryBtnText, secondaryBtnAction) {
    const container = document.getElementById('toastContainer');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = 'toast-card';

    let footerHtml = '';
    if (primaryBtnText || secondaryBtnText) {
        footerHtml = `<div class="toast-footer">`;
        if (secondaryBtnText) {
            footerHtml += `<button class="toast-btn toast-btn-secondary" onclick="this.closest('.toast-card').remove(); ${secondaryBtnAction || ''}">${secondaryBtnText}</button>`;
        }
        if (primaryBtnText) {
            footerHtml += `<button class="toast-btn toast-btn-primary" onclick="this.closest('.toast-card').remove(); ${primaryBtnAction || ''}">${primaryBtnText}</button>`;
        }
        footerHtml += `</div>`;
    }

    toast.innerHTML = `
        <div class="toast-header">
            <span class="toast-title">${title}</span>
            <span class="toast-close" onclick="this.closest('.toast-card').remove()">&times;</span>
        </div>
        <div class="toast-body">${message}</div>
        ${footerHtml}
    `;

    container.appendChild(toast);

    // Force layout and show
    setTimeout(() => {
        toast.classList.add('show');
    }, 50);

    // Auto dismiss after 5 seconds if no button
    if (!primaryBtnText && !secondaryBtnText) {
        setTimeout(() => {
            toast.classList.remove('show');
            setTimeout(() => { toast.remove(); }, 400);
        }, 5000);
    }
}

