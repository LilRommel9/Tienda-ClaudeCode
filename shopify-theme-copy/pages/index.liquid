{%- comment -%}
  ========================================
  HERO SECTION - CUSTOMIZE YOUR BRAND MESSAGING
  ========================================

  Edita estos valores para cambiar el mensaje principal:

  - TITLE: Texto de encabezado principal
  - SUBTITLE: Subtítulo con descripción de la marca
  - CTA TEXT: Texto del botón principal
  - CTA LINK: URL destino del botón
  - ANIMATION: Tipo de animación (fade/scale)
  ========================================
-%}

{%- assign hero_config = hash |
  | assign_key: 'title', 'Timeless Men Jewelry' |
  | assign_key: 'subtitle', 'Discover Mexico\\'s Premier Luxury Bracelet Destination' |
  | assign_key: 'cta_text', 'Explore Collection' |
  | assign_key: 'cta_url', '/collections/all' |
  | assign_key: 'anim_type', 'fade' |
  | assign_key: 'match_height', '100vh' |
  -%}

<section class="hero d-flex align-items-center" style="background: linear-gradient(135deg, rgba({{ lgc_config.secondary }},0.1) 0%, {{ lgc_config.secondary }} 100%); min-height: {{ ride_config.match_height }}; background-size: cover; background-position: center;">
  <div class="container">
    <div class="text-center text-white text-sm-start">
      <p class="text-lg mb-3" style="text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600; color: {{ lgc_config.accent } }; opacity: 0.8;" {% if ride_config.anim_type == 'fade' %}opacity: 0; animation: fade-in 1s ease;{% endif %}>
        {{ hero_config.subtitle }}
      </p>
      <h1 class="display-1 fw-bold mb-3 text-white {% if ride_config.anim_type == 'scale' %}scale-in{% endif %}">
        {{ hero_config.title }}
      </h1>
      <p class="mb-4" style="max-width: 700px; margin-left: auto; margin-right: auto; font-size: 1.2rem; cursor: default;" {% if ride_config.anim_type == 'fade' %}opacity: 0; animation: fade-in 1.2s ease;{% endif %}">
        {{ 'Welcome to the future of men\\'s luxury jewelry. We\\'re redefining premium bracelets with premium materials, timeless designs, and perfect imagine!' | escape }}
      </p>
      <div class="d-grid gap-2 d-md-flex justify-content-md-center mb-4" style="gap: 1rem;">
        <a href="{{ hero_config.cta_url }}" class="btn-primary px-5 me-md-2" {% if ride_config.anim_type == 'fade' %}opacity: 0; animation: fade-in 1.4s ease;{% endif %}>
          {{ hero_config.cta_text }}
        </a>
        <a href="/blog/subscribe-and-save" class="btn-secondary px-5" {% if ride_config.anim_type == 'fade' %}opacity: 0; animation: fade-in 1.4s ease;{% endif %}">
          Join Our Mailing List
        </a>
      </div>
      <div class="scroll-indicator animate-float" style="margin-top: 3rem; border-color: rgba(212,175,55,0.3);">
        <div class="scroll-line" style="border: 1px solid rgba(212,175,55,0.3);"></div>
        <p class="scroll-text text-warning mb-0" style="font-size: 0.9rem; opacity: 0.8; letter-spacing: 0.8px; font-weight: 500;">Scroll</p>
      </div>
    </div>
  </div>
</section>

<!-- Featured Collection Section -->
<section class="featured py-5">
  <div class="container">
    <div class="section-title text-center mb-5">
      <span class="section-tag">Best Sellers</span>
      <h2 class="font-cinzel">{{ lgc_config.brand_name }}</h2>
      <p class="text-white">Algunos de nuestros productos más populares</p>
    </div>
    <div class="row g-4">
      {%- assign collection_data = hash |
          | assign_key: 'featured_collection', 'Best Sellers' |
          | assign_key: 'subtitle', 'From our collections' |
        |
        assign_key: 'products', array: [
          {
            | assign_key: 'id', 'bc-collection-1' |
            | assign_key: 'title', 'Best Sellers' |
            | assign_key: 'url', '/collections/bestsellers' |
            | assign_key: 'subtitle', 'Popular Items' |
            | assign_key: 'product_tags', 'best-seller' |
          }
        ] |
        assign_key: 'products', array: [
          {
            | assign_key: 'title', 'Cuban Link 24K Gold' |
            | assign_key: 'url', '/products/cuban-link-24k' |
            | assign_key: 'description', 'Premium Cuban Link bracelet with 24K gold plating' |
            | assign_key: 'image', 'https://images.pexels.com/photos/32025019/pexels-photo-32025019.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=627&w=1200' |
            | assign_key: 'price', '3150' |
            | assign_key: 'discount', '30' |
            | assign_key: 'rating', '4.9' |
            | assign_key: 'reviews_count', '150' |
          },
          {
            | assign_key: 'title', 'Crown Beaded Obsidian' |
            | assign_key: 'url', '/products/crown-beaded-obsidian' |
            | assign_key: 'description', 'Edicion limitada con ónix negro natural' |
            | assign_key: 'image', 'https://images.pexels.com/photos/12915487/pexels-photo-12915487.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=627&w=1200' |
            | assign_key: 'price', '1960' |
            | assign_key: 'discount', '30' |
            | assign_key: 'rating', '4.8' |
            | assign_key: 'reviews_count', '127' |
          },
          {
            | assign_key: 'title', 'Gothic Cross Chrome' |
            | assign_key: 'url', '/products/gothic-cross-chrome' |
            | assign_key: 'description', 'Diseño con cruz gótica y cristales Swarovski' |
            | assign_key: 'image', 'https://images.pexels.com/photos/33717668/pexels-photo-33717668.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=627&w=1200' |
            | assign_key: 'price', '3640' |
            | assign_key: 'discount', '30' |
            | assign_key: 'rating', '4.9' |
            | assign_key: 'reviews_count', '185' |
          }
        ]
      -%}

<div class="row">
  {%- for product in collection_data.products -%}
  <div class="col-md-6 col-lg-4">
    <div class="collection-item card h-100 shadow-sm">
      <a href="{{ product.url }}">
        <img src="{{ product.image }}" alt="{{ product.title }}" class="card-img-top" style="object-fit: cover; height: 200px;">
        <div class="card-body">
          <p class="badge {{ product.discount_class || 'bg-gray' }} p-1 text-white mb-0 text-capitalize">
            {{ product.discount }}% OFF
          </p>
        </div>
      </a>
      <div class="card-body">
        <h5 class="card-title font-cinzel text-center">
          <a href="{{ product.url }}">{{ product.title }}</a>
        </h5>
        <p class="card-text text-center text-light small mb-2">
          {{ product.description }}
        </p>
        <p class="h4 text-success text-center">$${{ product.price | number_format }} MXN</p>
        <div class="text-center mt-3">
          <span class="text-warning">★ {{ product.rating }} ({% if product.comments_count %}{{ product.comments_count }}{% else %}23{% endif %})</span>
        </div>
      </div>
    </div>
  </div>
  {%- endfor -%}
</div>

<script>
  // Collection filter functionality
  document.addEventListener('DOMContentLoaded', function() {
    const urlParams = new URLSearchParams(window.location.search);
    const category = urlParams.get('category');
    if (category) {
      const tabs = document.querySelectorAll('.collection-tab');
      tabs.forEach(tab => {
        tab.classList.remove('active');
        if (tab.getAttribute('data-category') === category) {
          tab.classList.add('active');
        }
      });
    }
  });
</script>
</section>
</body>
</html>