{%- comment -%}
  Footer — Premium dark footer with columns, socials, newsletter
{%- endcomment -%}

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <div class="footer-brand__logo">{{ settings.brand_name }}</div>
        <p class="footer-brand__text">
          Joyería premium diseñada para durar. Materiales de la más alta calidad con garantía de por vida.
        </p>
        <div class="footer-socials">
          {%- if settings.instagram_url -%}
            <a href="{{ settings.instagram_url }}" class="footer-socials__link" aria-label="Instagram" target="_blank" rel="noopener">
              <i class="fab fa-instagram"></i>
            </a>
          {%- endif -%}
          {%- if settings.facebook_url -%}
            <a href="{{ settings.facebook_url }}" class="footer-socials__link" aria-label="Facebook" target="_blank" rel="noopener">
              <i class="fab fa-facebook-f"></i>
            </a>
          {%- endif -%}
          {%- if settings.twitter_url -%}
            <a href="{{ settings.twitter_url }}" class="footer-socials__link" aria-label="Twitter" target="_blank" rel="noopener">
              <i class="fab fa-x-twitter"></i>
            </a>
          {%- endif -%}
          <a href="https://wa.me/{{ settings.whatsapp_number }}" class="footer-socials__link" aria-label="WhatsApp" target="_blank" rel="noopener">
            <i class="fab fa-whatsapp"></i>
          </a>
        </div>
      </div>

      <!-- Shop Column -->
      <div class="footer-column">
        <h4 class="footer-column__title">Tienda</h4>
        <div class="footer-column__links">
          <a href="/collections/all" class="footer-column__link">Todas las Colecciones</a>
          <a href="/collections/new" class="footer-column__link">Nuevos Lanzamientos</a>
          <a href="/collections/bestsellers" class="footer-column__link">Más Vendidos</a>
          <a href="/pages/about" class="footer-column__link">Nuestra Historia</a>
        </div>
      </div>

      <!-- Support Column -->
      <div class="footer-column">
        <h4 class="footer-column__title">Soporte</h4>
        <div class="footer-column__links">
          <a href="/pages/contact" class="footer-column__link">Contacto</a>
          <a href="/pages/shipping" class="footer-column__link">Envíos y Devoluciones</a>
          <a href="/pages/faq" class="footer-column__link">Preguntas Frecuentes</a>
          <a href="/pages/warranty" class="footer-column__link">Garantía</a>
        </div>
      </div>

      <!-- Contact Column -->
      <div class="footer-column">
        <h4 class="footer-column__title">Contacto</h4>
        <div class="footer-column__links">
          <span class="footer-column__link">
            <i class="fas fa-envelope" style="margin-right: 0.5rem; font-size: 0.8em;"></i>
            {{ settings.email }}
          </span>
          <span class="footer-column__link">
            <i class="fas fa-phone" style="margin-right: 0.5rem; font-size: 0.8em;"></i>
            {{ settings.phone }}
          </span>
          <a href="https://wa.me/{{ settings.whatsapp_number }}" class="footer-column__link" target="_blank" rel="noopener">
            <i class="fab fa-whatsapp" style="margin-right: 0.5rem;"></i>
            WhatsApp
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="footer-bottom__copy">
        &copy; {{ 'now' | date: "%Y" }} {{ settings.brand_name }}. Todos los derechos reservados.
      </p>
      <div class="footer-bottom__links">
        <a href="/pages/privacy" class="footer-bottom__link">Privacidad</a>
        <a href="/pages/terms" class="footer-bottom__link">Términos</a>
        <a href="/pages/cookies" class="footer-bottom__link">Cookies</a>
      </div>
    </div>
  </div>
</footer>