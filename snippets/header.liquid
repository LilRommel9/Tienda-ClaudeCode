{%- comment -%}
  Header — Modern sticky header with blur effect
  Transparent on top, white + blur on scroll
{%- endcomment -%}

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="{{ shop.url }}" class="header-logo">
      {%- if settings.logo -%}
        <img src="{{ settings.logo | img_url: '150x' }}" alt="{{ shop.name }}" class="header-logo__img">
      {%- endif -%}
      <span class="header-logo__text">{{ settings.brand_name }}</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="header-nav" id="desktop-nav">
      <a href="{{ shop.url }}" class="header-nav__link header-nav__link--active">Inicio</a>
      <a href="/collections/all" class="header-nav__link">Colecciones</a>
      <a href="/pages/about" class="header-nav__link">Nosotros</a>
      <a href="/pages/contact" class="header-nav__link">Contacto</a>
    </nav>

    <!-- Actions -->
    <div class="header-actions">
      <a href="/cart" class="header-cart" aria-label="Carrito de compras">
        <i class="fas fa-shopping-bag header-cart__icon"></i>
        {%- if cart.item_count > 0 -%}
          <span class="header-cart__badge">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <!-- Mobile Menu Toggle -->
      <button class="menu-toggle" id="menu-toggle" aria-label="Abrir menú">
        <span class="menu-toggle__bar"></span>
        <span class="menu-toggle__bar"></span>
        <span class="menu-toggle__bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Overlay -->
  <div class="mobile-nav" id="mobile-nav">
    <a href="{{ shop.url }}" class="mobile-nav__link">Inicio</a>
    <a href="/collections/all" class="mobile-nav__link">Colecciones</a>
    <a href="/pages/about" class="mobile-nav__link">Nosotros</a>
    <a href="/pages/contact" class="mobile-nav__link">Contacto</a>
    <a href="/cart" class="mobile-nav__link">Carrito ({{ cart.item_count }})</a>
  </div>
</header>