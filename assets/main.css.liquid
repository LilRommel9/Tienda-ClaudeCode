/* =========================================
   LOSTGENCLUB — EVIE RING INSPIRED THEME
   Modern, Premium, Purple Palette
   ========================================= */

/* --- CSS VARIABLES / DESIGN TOKENS --- */
:root {
  /* Colors */
  --deep-purple: #1a0a2e;
  --brand-purple: #6b3fa0;
  --brand-purple-light: #8b5fcf;
  --brand-purple-dark: #4a2670;
  --lavender: #e8dff5;
  --soft-lilac: #f5f0ff;
  --cream: #faf8ff;
  --white: #ffffff;
  --dark-text: #1a1a2e;
  --body-text: #374151;
  --muted-text: #6b7280;
  --light-border: #e5e7eb;
  --accent-green: #2d8f5e;
  --accent-teal: #0d9488;
  --soft-pink: #fce7f3;
  --soft-green: #d1fae5;

  /* Gradients */
  --hero-gradient: linear-gradient(135deg, #1a0a2e 0%, #2d1b4e 30%, #6b3fa0 70%, #a78bfa 100%);
  --hero-gradient-alt: linear-gradient(180deg, #1a0a2e 0%, #3b1d6e 50%, #7c4dbd 100%);
  --card-gradient: linear-gradient(135deg, rgba(107, 63, 160, 0.05) 0%, rgba(232, 223, 245, 0.3) 100%);
  --cta-gradient: linear-gradient(135deg, #6b3fa0 0%, #8b5fcf 100%);
  --dark-section-gradient: linear-gradient(135deg, #1a0a2e 0%, #2d1b4e 100%);

  /* Typography */
  --font-heading: 'Outfit', sans-serif;
  --font-body: 'Inter', sans-serif;

  /* Spacing */
  --section-padding: 6rem 0;
  --section-padding-sm: 4rem 0;
  --container-max: 1200px;
  --container-padding: 0 1.5rem;

  /* Borders & Radius */
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 20px;
  --radius-xl: 28px;
  --radius-pill: 9999px;

  /* Shadows */
  --shadow-sm: 0 1px 3px rgba(26, 10, 46, 0.06);
  --shadow-md: 0 4px 16px rgba(26, 10, 46, 0.08);
  --shadow-lg: 0 8px 32px rgba(26, 10, 46, 0.12);
  --shadow-xl: 0 16px 48px rgba(26, 10, 46, 0.16);
  --shadow-purple: 0 4px 24px rgba(107, 63, 160, 0.25);

  /* Transitions */
  --transition-fast: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-base: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-slow: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-spring: 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* --- RESET & BASE --- */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-body);
  font-size: 1rem;
  line-height: 1.6;
  color: var(--body-text);
  background-color: var(--white);
  overflow-x: hidden;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

a {
  text-decoration: none;
  color: inherit;
  transition: color var(--transition-fast);
}

ul, ol {
  list-style: none;
}

button {
  cursor: pointer;
  border: none;
  background: none;
  font-family: inherit;
}

/* --- CONTAINER --- */
.container {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: var(--container-padding);
}

.container--narrow {
  max-width: 900px;
}

.container--wide {
  max-width: 1400px;
}

/* --- TYPOGRAPHY --- */
h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  font-weight: 700;
  line-height: 1.2;
  color: var(--dark-text);
}

h1 { font-size: clamp(2.5rem, 5vw, 4rem); }
h2 { font-size: clamp(2rem, 4vw, 3rem); }
h3 { font-size: clamp(1.5rem, 3vw, 2rem); }
h4 { font-size: clamp(1.125rem, 2vw, 1.5rem); }

.section-eyebrow {
  display: inline-block;
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--brand-purple);
  margin-bottom: 0.75rem;
}

.section-eyebrow--light {
  color: rgba(255, 255, 255, 0.7);
}

.section-description {
  font-size: 1.125rem;
  color: var(--muted-text);
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.7;
}

/* --- BUTTONS --- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.875rem 2rem;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 600;
  border-radius: var(--radius-pill);
  transition: all var(--transition-base);
  position: relative;
  overflow: hidden;
  white-space: nowrap;
}

.btn--primary {
  background: var(--cta-gradient);
  color: var(--white);
  box-shadow: var(--shadow-purple);
}

.btn--primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(107, 63, 160, 0.4);
}

.btn--primary:active {
  transform: translateY(0);
}

.btn--outline {
  background: transparent;
  color: var(--brand-purple);
  border: 2px solid var(--brand-purple);
}

.btn--outline:hover {
  background: var(--brand-purple);
  color: var(--white);
  transform: translateY(-2px);
}

.btn--outline-light {
  background: transparent;
  color: var(--white);
  border: 2px solid rgba(255, 255, 255, 0.4);
}

.btn--outline-light:hover {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.8);
  transform: translateY(-2px);
}

.btn--dark {
  background: var(--dark-text);
  color: var(--white);
}

.btn--dark:hover {
  background: #2d2d4e;
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.btn--sm {
  padding: 0.625rem 1.5rem;
  font-size: 0.875rem;
}

.btn--lg {
  padding: 1rem 2.5rem;
  font-size: 1rem;
}

.btn-group {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* --- HEADER / NAVBAR --- */
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: 1rem 0;
  transition: all var(--transition-base);
}

.site-header--scrolled {
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: var(--shadow-sm);
  padding: 0.75rem 0;
}

.site-header--scrolled .header-nav__link,
.site-header--scrolled .header-logo__text {
  color: var(--dark-text);
}

.site-header--scrolled .header-cart__icon {
  color: var(--dark-text);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: var(--container-max);
  margin: 0 auto;
  padding: var(--container-padding);
}

.header-logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  z-index: 1001;
}

.header-logo__img {
  height: 32px;
  width: auto;
}

.header-logo__text {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--white);
  transition: color var(--transition-base);
}

.header-nav {
  display: flex;
  align-items: center;
  gap: 2rem;
}

.header-nav__link {
  font-size: 0.9375rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  transition: color var(--transition-fast);
  position: relative;
}

.header-nav__link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--brand-purple);
  border-radius: 1px;
  transition: width var(--transition-base);
}

.header-nav__link:hover::after,
.header-nav__link--active::after {
  width: 100%;
}

.header-nav__link:hover {
  color: var(--white);
}

.site-header--scrolled .header-nav__link:hover {
  color: var(--brand-purple);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  z-index: 1001;
}

.header-cart {
  position: relative;
  display: flex;
  align-items: center;
}

.header-cart__icon {
  font-size: 1.25rem;
  color: var(--white);
  transition: color var(--transition-fast);
}

.header-cart__badge {
  position: absolute;
  top: -8px;
  right: -10px;
  background: var(--brand-purple);
  color: var(--white);
  font-size: 0.625rem;
  font-weight: 700;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Mobile Menu Toggle */
.menu-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  width: 28px;
  cursor: pointer;
  z-index: 1001;
}

.menu-toggle__bar {
  width: 100%;
  height: 2px;
  background: var(--white);
  border-radius: 2px;
  transition: all var(--transition-base);
}

.site-header--scrolled .menu-toggle__bar {
  background: var(--dark-text);
}

.menu-toggle--active .menu-toggle__bar:nth-child(1) {
  transform: rotate(45deg) translate(5px, 5px);
}

.menu-toggle--active .menu-toggle__bar:nth-child(2) {
  opacity: 0;
}

.menu-toggle--active .menu-toggle__bar:nth-child(3) {
  transform: rotate(-45deg) translate(5px, -5px);
}

/* Mobile Nav */
.mobile-nav {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 10, 46, 0.98);
  backdrop-filter: blur(20px);
  z-index: 999;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  opacity: 0;
  visibility: hidden;
  transition: all var(--transition-base);
}

.mobile-nav--open {
  opacity: 1;
  visibility: visible;
}

.mobile-nav__link {
  font-family: var(--font-heading);
  font-size: 1.75rem;
  font-weight: 600;
  color: var(--white);
  transition: color var(--transition-fast);
}

.mobile-nav__link:hover {
  color: var(--brand-purple-light);
}

/* --- HERO SECTION --- */
.hero-section {
  position: relative;
  background: var(--hero-gradient);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 8rem 1.5rem 6rem;
  overflow: hidden;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(ellipse at 30% 50%, rgba(139, 95, 207, 0.15) 0%, transparent 60%),
              radial-gradient(ellipse at 70% 30%, rgba(167, 139, 250, 0.1) 0%, transparent 50%);
  animation: heroGlow 15s ease-in-out infinite alternate;
}

@keyframes heroGlow {
  0% { transform: translate(0, 0) rotate(0deg); }
  100% { transform: translate(-5%, 5%) rotate(3deg); }
}

.hero-content {
  position: relative;
  z-index: 2;
  max-width: 800px;
  margin: 0 auto;
}

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 1.5rem;
  animation: fadeInUp 0.8s ease-out;
}

.hero-eyebrow__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--brand-purple-light);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.5); }
}

.hero-title {
  font-family: var(--font-heading);
  font-size: clamp(2.75rem, 6vw, 4.5rem);
  font-weight: 800;
  color: var(--white);
  line-height: 1.1;
  margin-bottom: 1.5rem;
  animation: fadeInUp 0.8s ease-out 0.15s both;
}

.hero-title span {
  background: linear-gradient(135deg, #c4b5fd, #a78bfa, #8b5fcf);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: clamp(1rem, 2vw, 1.25rem);
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.7;
  max-width: 550px;
  margin: 0 auto 2.5rem;
  animation: fadeInUp 0.8s ease-out 0.3s both;
}

.hero-buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
  animation: fadeInUp 0.8s ease-out 0.45s both;
}

.hero-image-wrapper {
  position: relative;
  margin-top: 4rem;
  animation: fadeInUp 1s ease-out 0.6s both;
}

.hero-image-wrapper img {
  max-width: 500px;
  margin: 0 auto;
  border-radius: var(--radius-lg);
}

.hero-scroll-indicator {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  animation: fadeInUp 1s ease-out 0.8s both;
}

.hero-scroll-indicator__line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.5), transparent);
  animation: scrollLine 2s ease-in-out infinite;
}

@keyframes scrollLine {
  0% { transform: scaleY(0); transform-origin: top; }
  50% { transform: scaleY(1); transform-origin: top; }
  51% { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}

.hero-scroll-indicator__text {
  font-size: 0.6875rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.4);
}

/* --- PRESS QUOTE SECTION --- */
.press-quote-section {
  padding: 4rem 0;
  background: var(--white);
  border-bottom: 1px solid var(--light-border);
}

.press-quote {
  text-align: center;
  max-width: 800px;
  margin: 0 auto;
}

.press-quote__text {
  font-family: var(--font-heading);
  font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  font-weight: 500;
  color: var(--dark-text);
  font-style: italic;
  line-height: 1.5;
  margin-bottom: 1.5rem;
  position: relative;
}

.press-quote__text::before {
  content: '"';
  font-size: 4rem;
  color: var(--brand-purple);
  opacity: 0.3;
  position: absolute;
  top: -1.5rem;
  left: -0.5rem;
  font-family: Georgia, serif;
  line-height: 1;
}

.press-quote__source {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  font-size: 0.875rem;
  color: var(--muted-text);
  font-weight: 500;
}

.press-quote__source-logo {
  height: 20px;
  width: auto;
  opacity: 0.6;
}

.press-quote__divider {
  width: 1px;
  height: 16px;
  background: var(--light-border);
}

/* --- PRODUCT FEATURE SECTION --- */
.product-feature-section {
  padding: var(--section-padding);
  background: var(--cream);
}

.product-feature {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.product-feature--reversed {
  direction: rtl;
}

.product-feature--reversed > * {
  direction: ltr;
}

.product-feature__media {
  position: relative;
}

.product-feature__image {
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xl);
  transition: transform var(--transition-slow);
}

.product-feature__image:hover {
  transform: scale(1.02);
}

.product-feature__badge {
  position: absolute;
  top: 1rem;
  left: 1rem;
  background: var(--accent-green);
  color: var(--white);
  font-size: 0.75rem;
  font-weight: 600;
  padding: 0.375rem 0.875rem;
  border-radius: var(--radius-pill);
}

.product-feature__content {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.product-feature__title {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 700;
  color: var(--dark-text);
}

.product-feature__text {
  font-size: 1.0625rem;
  color: var(--muted-text);
  line-height: 1.8;
}

.product-feature__list {
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}

.product-feature__list-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-size: 0.9375rem;
  color: var(--body-text);
}

.product-feature__list-icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  background: var(--brand-purple);
  color: var(--white);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.625rem;
  margin-top: 2px;
}

.product-feature__price {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
}

.product-feature__price-current {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  color: var(--dark-text);
}

.product-feature__price-old {
  font-size: 1.125rem;
  color: var(--muted-text);
  text-decoration: line-through;
}

/* --- DARK AWARD SECTION --- */
.award-section {
  padding: var(--section-padding);
  background: var(--dark-section-gradient);
  position: relative;
  overflow: hidden;
}

.award-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at 50% 50%, rgba(107, 63, 160, 0.15), transparent 70%);
}

.award-section .container {
  position: relative;
  z-index: 2;
}

.award-section__header {
  text-align: center;
  margin-bottom: 4rem;
}

.award-section__title {
  color: var(--white);
  margin-bottom: 1rem;
}

.award-section__subtitle {
  font-size: 1.125rem;
  color: rgba(255, 255, 255, 0.6);
  max-width: 500px;
  margin: 0 auto;
}

.award-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.award-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-lg);
  padding: 2rem;
  text-align: center;
  transition: all var(--transition-base);
  backdrop-filter: blur(10px);
}

.award-card:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(107, 63, 160, 0.3);
  transform: translateY(-4px);
  box-shadow: 0 8px 32px rgba(107, 63, 160, 0.2);
}

.award-card__image {
  border-radius: var(--radius-md);
  margin-bottom: 1.5rem;
  overflow: hidden;
}

.award-card__image img {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  transition: transform var(--transition-slow);
}

.award-card:hover .award-card__image img {
  transform: scale(1.05);
}

.award-card__title {
  font-size: 1.125rem;
  color: var(--white);
  margin-bottom: 0.5rem;
}

.award-card__text {
  font-size: 0.875rem;
  color: rgba(255, 255, 255, 0.5);
}

/* --- APP SHOWCASE SECTION --- */
.app-showcase-section {
  padding: var(--section-padding);
  background: var(--lavender);
  position: relative;
  overflow: hidden;
}

.app-showcase {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.app-showcase__content {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.app-showcase__title {
  color: var(--dark-text);
}

.app-showcase__text {
  font-size: 1.0625rem;
  color: var(--body-text);
  line-height: 1.8;
}

.app-showcase__media {
  position: relative;
  display: flex;
  justify-content: center;
}

.app-showcase__phone {
  max-width: 300px;
  border-radius: 32px;
  box-shadow: var(--shadow-xl);
}

/* --- FEATURES GRID --- */
.features-section {
  padding: var(--section-padding);
  background: var(--white);
}

.features-section__header {
  text-align: center;
  margin-bottom: 4rem;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.feature-card {
  background: var(--cream);
  border-radius: var(--radius-lg);
  padding: 2rem;
  transition: all var(--transition-base);
  border: 1px solid transparent;
}

.feature-card:hover {
  background: var(--white);
  border-color: var(--lavender);
  box-shadow: var(--shadow-lg);
  transform: translateY(-4px);
}

.feature-card__icon {
  width: 48px;
  height: 48px;
  background: var(--lavender);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  font-size: 1.25rem;
  color: var(--brand-purple);
  transition: all var(--transition-base);
}

.feature-card:hover .feature-card__icon {
  background: var(--brand-purple);
  color: var(--white);
}

.feature-card__title {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--dark-text);
  margin-bottom: 0.5rem;
}

.feature-card__text {
  font-size: 0.9375rem;
  color: var(--muted-text);
  line-height: 1.6;
}

/* --- HEALTH GOALS / BENEFITS SECTION --- */
.goals-section {
  padding: var(--section-padding);
  background: var(--soft-lilac);
}

.goals-section__header {
  text-align: center;
  margin-bottom: 4rem;
}

.goals-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
}

.goal-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  text-align: center;
  transition: all var(--transition-base);
  border: 1px solid rgba(107, 63, 160, 0.08);
  cursor: pointer;
}

.goal-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
  border-color: var(--brand-purple);
}

.goal-card__emoji {
  font-size: 2.5rem;
  margin-bottom: 1rem;
}

.goal-card__title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--dark-text);
  margin-bottom: 0.375rem;
}

.goal-card__text {
  font-size: 0.8125rem;
  color: var(--muted-text);
}

/* --- DESIGNED FOR SECTION --- */
.designed-section {
  padding: var(--section-padding);
  background: var(--white);
}

.designed-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.designed-card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  aspect-ratio: 3/4;
}

.designed-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}

.designed-card:hover .designed-card__image {
  transform: scale(1.08);
}

.designed-card__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 2rem;
  background: linear-gradient(to top, rgba(26, 10, 46, 0.8), transparent);
  color: var(--white);
}

.designed-card__title {
  font-size: 1.25rem;
  color: var(--white);
  margin-bottom: 0.25rem;
}

.designed-card__text {
  font-size: 0.875rem;
  color: rgba(255, 255, 255, 0.7);
}

/* --- NEWSLETTER / CTA SECTION --- */
.newsletter-section {
  padding: var(--section-padding);
  background: var(--lavender);
  text-align: center;
}

.newsletter-section__header {
  margin-bottom: 2.5rem;
}

.newsletter-section__title {
  color: var(--dark-text);
  margin-bottom: 0.75rem;
}

.newsletter-section__text {
  font-size: 1.0625rem;
  color: var(--muted-text);
  max-width: 500px;
  margin: 0 auto;
}

.newsletter-form {
  display: flex;
  gap: 0.75rem;
  max-width: 480px;
  margin: 0 auto;
}

.newsletter-form__input {
  flex: 1;
  padding: 0.875rem 1.25rem;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  border: 2px solid var(--light-border);
  border-radius: var(--radius-pill);
  background: var(--white);
  color: var(--dark-text);
  outline: none;
  transition: border-color var(--transition-fast);
}

.newsletter-form__input::placeholder {
  color: var(--muted-text);
}

.newsletter-form__input:focus {
  border-color: var(--brand-purple);
}

.newsletter-form__btn {
  padding: 0.875rem 2rem;
  background: var(--cta-gradient);
  color: var(--white);
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 600;
  border: none;
  border-radius: var(--radius-pill);
  cursor: pointer;
  transition: all var(--transition-base);
  white-space: nowrap;
}

.newsletter-form__btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-purple);
}

.newsletter-disclaimer {
  font-size: 0.8125rem;
  color: var(--muted-text);
  margin-top: 1rem;
}

/* --- SITE FOOTER --- */
.site-footer {
  background: var(--deep-purple);
  color: rgba(255, 255, 255, 0.7);
  padding: 4rem 0 2rem;
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 3rem;
  margin-bottom: 3rem;
}

.footer-brand__logo {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 1rem;
}

.footer-brand__text {
  font-size: 0.9375rem;
  line-height: 1.7;
  margin-bottom: 1.5rem;
  max-width: 300px;
}

.footer-socials {
  display: flex;
  gap: 0.75rem;
}

.footer-socials__link {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.6);
  font-size: 0.875rem;
  transition: all var(--transition-fast);
}

.footer-socials__link:hover {
  background: var(--brand-purple);
  color: var(--white);
  transform: translateY(-2px);
}

.footer-column__title {
  font-family: var(--font-heading);
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--white);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 1.25rem;
}

.footer-column__links {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.footer-column__link {
  font-size: 0.9375rem;
  color: rgba(255, 255, 255, 0.5);
  transition: color var(--transition-fast);
}

.footer-column__link:hover {
  color: var(--white);
}

.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  padding-top: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-bottom__copy {
  font-size: 0.8125rem;
  color: rgba(255, 255, 255, 0.4);
}

.footer-bottom__links {
  display: flex;
  gap: 1.5rem;
}

.footer-bottom__link {
  font-size: 0.8125rem;
  color: rgba(255, 255, 255, 0.4);
  transition: color var(--transition-fast);
}

.footer-bottom__link:hover {
  color: rgba(255, 255, 255, 0.8);
}

/* --- ANIMATIONS --- */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(24px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.animate-on-scroll {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s ease-out, transform 0.7s ease-out;
}

.animate-on-scroll--visible {
  opacity: 1;
  transform: translateY(0);
}

.animate-on-scroll--delay-1 { transition-delay: 0.1s; }
.animate-on-scroll--delay-2 { transition-delay: 0.2s; }
.animate-on-scroll--delay-3 { transition-delay: 0.3s; }
.animate-on-scroll--delay-4 { transition-delay: 0.4s; }

/* --- PRODUCT CARDS (for collection/grid pages) --- */
.product-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--light-border);
  transition: all var(--transition-base);
}

.product-card:hover {
  border-color: var(--lavender);
  box-shadow: var(--shadow-lg);
  transform: translateY(-6px);
}

.product-card__image-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1;
  background: var(--cream);
}

.product-card__image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}

.product-card:hover .product-card__image-wrap img {
  transform: scale(1.06);
}

.product-card__badge {
  position: absolute;
  top: 0.75rem;
  left: 0.75rem;
  background: var(--brand-purple);
  color: var(--white);
  font-size: 0.6875rem;
  font-weight: 700;
  padding: 0.25rem 0.75rem;
  border-radius: var(--radius-pill);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.product-card__body {
  padding: 1.25rem;
}

.product-card__title {
  font-family: var(--font-heading);
  font-size: 1.0625rem;
  font-weight: 600;
  color: var(--dark-text);
  margin-bottom: 0.5rem;
}

.product-card__price {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.product-card__price-current {
  font-weight: 700;
  font-size: 1.125rem;
  color: var(--dark-text);
}

.product-card__price-old {
  font-size: 0.875rem;
  color: var(--muted-text);
  text-decoration: line-through;
}

.product-card__rating {
  display: flex;
  gap: 2px;
  color: #f59e0b;
  font-size: 0.8125rem;
  margin-bottom: 1rem;
}

.product-card__btn {
  width: 100%;
  padding: 0.75rem;
  background: var(--dark-text);
  color: var(--white);
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 600;
  border: none;
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all var(--transition-base);
}

.product-card__btn:hover {
  background: var(--brand-purple);
  box-shadow: var(--shadow-purple);
}

/* --- UTILITY CLASSES --- */
.text-center { text-align: center; }
.text-white { color: var(--white); }
.mt-0 { margin-top: 0; }
.mb-0 { margin-bottom: 0; }

/* --- RESPONSIVE --- */
@media (max-width: 1024px) {
  :root {
    --section-padding: 5rem 0;
  }

  .product-feature {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .product-feature--reversed {
    direction: ltr;
  }

  .award-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .features-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .goals-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .footer-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .app-showcase {
    grid-template-columns: 1fr;
    gap: 3rem;
    text-align: center;
  }

  .designed-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  :root {
    --section-padding: 4rem 0;
  }

  .header-nav {
    display: none;
  }

  .menu-toggle {
    display: flex;
  }

  .mobile-nav {
    display: flex;
  }

  .hero-section {
    min-height: auto;
    padding: 7rem 1.5rem 4rem;
  }

  .hero-title {
    font-size: clamp(2rem, 8vw, 3rem);
  }

  .press-quote__text {
    font-size: 1.125rem;
  }

  .award-grid {
    grid-template-columns: 1fr;
  }

  .features-grid {
    grid-template-columns: 1fr;
  }

  .goals-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .designed-grid {
    grid-template-columns: 1fr;
  }

  .newsletter-form {
    flex-direction: column;
  }

  .footer-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .footer-bottom {
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }

  .footer-bottom__links {
    justify-content: center;
  }

  .btn-group {
    justify-content: center;
  }
}

@media (max-width: 480px) {
  .goals-grid {
    grid-template-columns: 1fr;
  }

  .hero-buttons {
    flex-direction: column;
    align-items: center;
  }

  .hero-buttons .btn {
    width: 100%;
    max-width: 280px;
  }
}