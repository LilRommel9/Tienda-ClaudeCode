{%- comment -%}
  ========================================
  LOSTGENCLUB - HOME PAGE
  ========================================
  Diseño inspirado en Evie Ring.
  Secciones:
  1. Hero (gradiente púrpura)
  2. Press Quote
  3. Product Feature
  4. Award-Winning (fondo oscuro)
  5. App/Lifestyle Showcase
  6. Features Grid
  7. Goals/Benefits Cards
  8. Gallery "Designed For"
  9. Newsletter
  ========================================
{%- endcomment -%}


{%- comment -%} ====== SECTION 1: HERO ====== {%- endcomment -%}
<section class="hero-section" id="hero">
  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="hero-eyebrow__dot"></span>
      {{ settings.brand_tagline }}
    </div>

    <h1 class="hero-title">
      Presentamos<br>
      <span>{{ settings.brand_name }}</span>
    </h1>

    <p class="hero-subtitle">
      Joyería premium diseñada con los mejores materiales. {{ settings.material_note }}. Diseño que perdura.
    </p>

    <div class="hero-buttons">
      <a href="{{ settings.hero_cta_url | default: '/collections/all' }}" class="btn btn--primary btn--lg">
        {{ settings.hero_cta_text | default: 'Ver Colección' }}
        <i class="fas fa-arrow-right" style="font-size: 0.8em;"></i>
      </a>
      <a href="/pages/about" class="btn btn--outline-light btn--lg">
        Conoce Más
      </a>
    </div>

    {%- comment -%} Hero product images {%- endcomment -%}
    <div class="hero-image-wrapper">
      <img
        src="{{ 'bracelet-1.jpg' | asset_url }}"
        alt="{{ settings.brand_name }} - Producto Destacado"
        loading="eager"
        width="500"
        height="500"
        style="border-radius: 20px; box-shadow: 0 24px 64px rgba(0,0,0,0.4);"
      >
    </div>
  </div>

  <div class="hero-scroll-indicator">
    <div class="hero-scroll-indicator__line"></div>
    <span class="hero-scroll-indicator__text">Scroll</span>
  </div>
</section>


{%- comment -%} ====== SECTION 2: PRESS QUOTE ====== {%- endcomment -%}
<section class="press-quote-section animate-on-scroll" id="press-quote">
  <div class="container container--narrow">
    <div class="press-quote">
      <p class="press-quote__text">
        "{{ settings.brand_name }} es una de las mejores marcas de joyería masculina que hemos visto. La calidad del acero inoxidable 316L es impresionante."
      </p>
      <div class="press-quote__source">
        <span style="font-weight: 700; color: var(--dark-text);">GQ México</span>
        <span class="press-quote__divider"></span>
        <span>Estilo & Tendencias</span>
      </div>
    </div>
  </div>
</section>


{%- comment -%} ====== SECTION 3: PRODUCT FEATURE ====== {%- endcomment -%}
<section class="product-feature-section" id="product-feature">
  <div class="container">
    <div class="product-feature">
      <div class="product-feature__media animate-on-scroll">
        <img
          src="{{ 'bracelet-2.jpg' | asset_url }}"
          alt="{{ settings.brand_name }} - Producto Principal"
          class="product-feature__image"
          loading="lazy"
          width="560"
          height="560"
        >
        <span class="product-feature__badge">Nuevo</span>
      </div>
      <div class="product-feature__content animate-on-scroll animate-on-scroll--delay-2">
        <span class="section-eyebrow">Producto Estrella</span>
        <h2 class="product-feature__title">Colección Premium</h2>
        <p class="product-feature__text">
          Cada pieza está diseñada con precisión artesanal y los materiales más finos. Nuestras pulseras combinan durabilidad con un estilo que no pasa de moda.
        </p>
        <ul class="product-feature__list">
          <li class="product-feature__list-item">
            <span class="product-feature__list-icon"><i class="fas fa-check" style="font-size: 0.5rem;"></i></span>
            {{ settings.material_note }}
          </li>
          <li class="product-feature__list-item">
            <span class="product-feature__list-icon"><i class="fas fa-check" style="font-size: 0.5rem;"></i></span>
            Resistente al agua y al sudor
          </li>
          <li class="product-feature__list-item">
            <span class="product-feature__list-icon"><i class="fas fa-check" style="font-size: 0.5rem;"></i></span>
            {{ settings.warranty_message }}
          </li>
          <li class="product-feature__list-item">
            <span class="product-feature__list-icon"><i class="fas fa-check" style="font-size: 0.5rem;"></i></span>
            Envío gratis en compras mayores a ${{ settings.free_shipping_threshold }} MXN
          </li>
        </ul>
        <div class="btn-group" style="margin-top: 0.5rem;">
          <a href="/collections/all" class="btn btn--primary">Comprar Ahora</a>
          <a href="/pages/about" class="btn btn--outline">Más Detalles</a>
        </div>
      </div>
    </div>
  </div>
</section>


{%- comment -%} ====== SECTION 4: AWARD / SHOWCASE DARK ====== {%- endcomment -%}
<section class="award-section" id="award-section">
  <div class="container">
    <div class="award-section__header animate-on-scroll">
      <span class="section-eyebrow section-eyebrow--light">Nuestra Colección</span>
      <h2 class="award-section__title">Diseño Premiado,<br>Calidad Abierta</h2>
      <p class="award-section__subtitle">
        Cada pieza es una declaración de estilo. Descubre nuestra colección más aclamada.
      </p>
    </div>
    <div class="award-grid">
      <div class="award-card animate-on-scroll animate-on-scroll--delay-1">
        <div class="award-card__image">
          <img
            src="{{ 'bracelet-3.jpg' | asset_url }}"
            alt="Brazalete Premium 1"
            loading="lazy"
            width="400"
            height="400"
          >
        </div>
        <h4 class="award-card__title">Edición Signature</h4>
        <p class="award-card__text">Acero inoxidable 316L premium</p>
      </div>
      <div class="award-card animate-on-scroll animate-on-scroll--delay-2">
        <div class="award-card__image">
          <img
            src="{{ 'bracelet-4.jpg' | asset_url }}"
            alt="Brazalete Premium 2"
            loading="lazy"
            width="400"
            height="400"
          >
        </div>
        <h4 class="award-card__title">Edición Gold</h4>
        <p class="award-card__text">Baño de oro PVD 18K</p>
      </div>
      <div class="award-card animate-on-scroll animate-on-scroll--delay-3">
        <div class="award-card__image">
          <img
            src="{{ 'bracelet-5.jpg' | asset_url }}"
            alt="Brazalete Premium 3"
            loading="lazy"
            width="400"
            height="400"
          >
        </div>
        <h4 class="award-card__title">Edición Black</h4>
        <p class="award-card__text">Acabado mate exclusivo</p>
      </div>
    </div>
  </div>
</section>


{%- comment -%} ====== SECTION 5: APP / LIFESTYLE SHOWCASE ====== {%- endcomment -%}
<section class="app-showcase-section" id="lifestyle">
  <div class="container">
    <div class="app-showcase">
      <div class="app-showcase__content animate-on-scroll">
        <span class="section-eyebrow">Estilo de Vida</span>
        <h2 class="app-showcase__title">El Futuro del Estilo Masculino</h2>
        <p class="app-showcase__text">
          Nuestras piezas están diseñadas para acompañarte en cada momento.
          Desde reuniones de negocios hasta aventuras al aire libre, cada brazalete
          se adapta a tu estilo de vida sin comprometer calidad ni elegancia.
        </p>
        <div class="btn-group">
          <a href="/collections/all" class="btn btn--primary">Explorar Colección</a>
        </div>
      </div>
      <div class="app-showcase__media animate-on-scroll animate-on-scroll--delay-2">
        <img
          src="{{ 'bracelet-6.jpg' | asset_url }}"
          alt="Estilo de vida {{ settings.brand_name }}"
          style="border-radius: 20px; box-shadow: 0 16px 48px rgba(26, 10, 46, 0.15); max-width: 450px;"
          loading="lazy"
          width="450"
          height="500"
        >
      </div>
    </div>
  </div>
</section>


{%- comment -%} ====== SECTION 6: FEATURES GRID ====== {%- endcomment -%}
<section class="features-section" id="features">
  <div class="container">
    <div class="features-section__header animate-on-scroll">
      <span class="section-eyebrow">¿Por Qué Elegirnos?</span>
      <h2>La Diferencia {{ settings.brand_name }}</h2>
      <p class="section-description">
        Calidad, diseño y compromiso en cada pieza que creamos.
      </p>
    </div>
    <div class="features-grid">
      <div class="feature-card animate-on-scroll animate-on-scroll--delay-1">
        <div class="feature-card__icon">
          <i class="fas fa-shield-alt"></i>
        </div>
        <h4 class="feature-card__title">{{ settings.warranty_message }}</h4>
        <p class="feature-card__text">
          Todas nuestras piezas de acero inoxidable 316L vienen con garantía de por vida. Tu inversión está protegida.
        </p>
      </div>
      <div class="feature-card animate-on-scroll animate-on-scroll--delay-2">
        <div class="feature-card__icon">
          <i class="fas fa-tint-slash"></i>
        </div>
        <h4 class="feature-card__title">Waterproof</h4>
        <p class="feature-card__text">
          Resistente al agua, sudor y actividades deportivas. Diseñado para el uso diario sin preocupaciones.
        </p>
      </div>
      <div class="feature-card animate-on-scroll animate-on-scroll--delay-3">
        <div class="feature-card__icon">
          <i class="fas fa-gem"></i>
        </div>
        <h4 class="feature-card__title">Materiales Premium</h4>
        <p class="feature-card__text">
          {{ settings.material_note }}. Solo los mejores materiales para piezas que duran toda la vida.
        </p>
      </div>
      <div class="feature-card animate-on-scroll animate-on-scroll--delay-1">
        <div class="feature-card__icon">
          <i class="fas fa-truck-fast"></i>
        </div>
        <h4 class="feature-card__title">Envío Express</h4>
        <p class="feature-card__text">
          Envío gratis en compras mayores a ${{ settings.free_shipping_threshold }} MXN. Entrega en {{ settings.shipping_days }} días hábiles.
        </p>
      </div>
      <div class="feature-card animate-on-scroll animate-on-scroll--delay-2">
        <div class="feature-card__icon">
          <i class="fas fa-arrows-rotate"></i>
        </div>
        <h4 class="feature-card__title">Devolución Fácil</h4>
        <p class="feature-card__text">
          30 días para devoluciones sin complicaciones. Tu satisfacción es nuestra prioridad.
        </p>
      </div>
      <div class="feature-card animate-on-scroll animate-on-scroll--delay-3">
        <div class="feature-card__icon">
          <i class="fas fa-certificate"></i>
        </div>
        <h4 class="feature-card__title">Certificado de Autenticidad</h4>
        <p class="feature-card__text">
          Cada pieza incluye un certificado que garantiza la autenticidad de los materiales utilizados.
        </p>
      </div>
    </div>
  </div>
</section>


{%- comment -%} ====== SECTION 7: GOALS / BENEFITS ====== {%- endcomment -%}
<section class="goals-section" id="benefits">
  <div class="container">
    <div class="goals-section__header animate-on-scroll">
      <span class="section-eyebrow">Para Cada Ocasión</span>
      <h2>Elige Tu Estilo,<br>Define Tu Personalidad</h2>
      <p class="section-description">
        Nuestra colección se adapta a cada aspecto de tu vida. Encuentra la pieza perfecta para cada momento.
      </p>
    </div>
    <div class="goals-grid">
      <div class="goal-card animate-on-scroll animate-on-scroll--delay-1">
        <div class="goal-card__emoji">💼</div>
        <h4 class="goal-card__title">Negocios</h4>
        <p class="goal-card__text">Elegancia profesional para el día a día</p>
      </div>
      <div class="goal-card animate-on-scroll animate-on-scroll--delay-2">
        <div class="goal-card__emoji">🏋️</div>
        <h4 class="goal-card__title">Deporte</h4>
        <p class="goal-card__text">Resistente a tus actividades más intensas</p>
      </div>
      <div class="goal-card animate-on-scroll animate-on-scroll--delay-3">
        <div class="goal-card__emoji">🌊</div>
        <h4 class="goal-card__title">Aventura</h4>
        <p class="goal-card__text">Waterproof para viajes y naturaleza</p>
      </div>
      <div class="goal-card animate-on-scroll animate-on-scroll--delay-4">
        <div class="goal-card__emoji">🎉</div>
        <h4 class="goal-card__title">Eventos</h4>
        <p class="goal-card__text">Brilla en cada ocasión especial</p>
      </div>
      <div class="goal-card animate-on-scroll animate-on-scroll--delay-1">
        <div class="goal-card__emoji">🎁</div>
        <h4 class="goal-card__title">Regalos</h4>
        <p class="goal-card__text">El detalle perfecto para alguien especial</p>
      </div>
      <div class="goal-card animate-on-scroll animate-on-scroll--delay-2">
        <div class="goal-card__emoji">✨</div>
        <h4 class="goal-card__title">Casual</h4>
        <p class="goal-card__text">Estilo relajado con un toque de lujo</p>
      </div>
      <div class="goal-card animate-on-scroll animate-on-scroll--delay-3">
        <div class="goal-card__emoji">🖤</div>
        <h4 class="goal-card__title">Minimalista</h4>
        <p class="goal-card__text">Diseño limpio y sofisticado</p>
      </div>
      <div class="goal-card animate-on-scroll animate-on-scroll--delay-4">
        <div class="goal-card__emoji">👑</div>
        <h4 class="goal-card__title">Coleccionista</h4>
        <p class="goal-card__text">Ediciones limitadas para los más exigentes</p>
      </div>
    </div>
  </div>
</section>


{%- comment -%} ====== SECTION 8: DESIGNED FOR / GALLERY ====== {%- endcomment -%}
<section class="designed-section" id="gallery">
  <div class="container">
    <div style="text-align: center; margin-bottom: 4rem;" class="animate-on-scroll">
      <span class="section-eyebrow">Galería</span>
      <h2>Diseñado Para Ti</h2>
      <p class="section-description">
        Cada pieza cuenta una historia. Encuentra la tuya.
      </p>
    </div>
    <div class="designed-grid">
      <div class="designed-card animate-on-scroll animate-on-scroll--delay-1">
        <img
          src="{{ 'bracelet-1.jpg' | asset_url }}"
          alt="Estilo urbano"
          class="designed-card__image"
          loading="lazy"
          width="400"
          height="533"
        >
        <div class="designed-card__overlay">
          <h4 class="designed-card__title">Urban Style</h4>
          <p class="designed-card__text">Colección Urbana</p>
        </div>
      </div>
      <div class="designed-card animate-on-scroll animate-on-scroll--delay-2">
        <img
          src="{{ 'bracelet-2.jpg' | asset_url }}"
          alt="Estilo clásico"
          class="designed-card__image"
          loading="lazy"
          width="400"
          height="533"
        >
        <div class="designed-card__overlay">
          <h4 class="designed-card__title">Classic Edition</h4>
          <p class="designed-card__text">Colección Clásica</p>
        </div>
      </div>
      <div class="designed-card animate-on-scroll animate-on-scroll--delay-3">
        <img
          src="{{ 'bracelet-3.jpg' | asset_url }}"
          alt="Estilo premium"
          class="designed-card__image"
          loading="lazy"
          width="400"
          height="533"
        >
        <div class="designed-card__overlay">
          <h4 class="designed-card__title">Premium Gold</h4>
          <p class="designed-card__text">Colección Premium</p>
        </div>
      </div>
    </div>
  </div>
</section>


{%- comment -%} ====== SECTION 9: NEWSLETTER ====== {%- endcomment -%}
<section class="newsletter-section" id="newsletter">
  <div class="container container--narrow">
    <div class="newsletter-section__header animate-on-scroll">
      <span class="section-eyebrow">Únete al Club</span>
      <h2 class="newsletter-section__title">No Te Pierdas Nada</h2>
      <p class="newsletter-section__text">
        Suscríbete para recibir acceso anticipado a lanzamientos, ofertas exclusivas y contenido VIP.
      </p>
    </div>
    <form class="newsletter-form animate-on-scroll animate-on-scroll--delay-1" id="newsletter-form">
      <input
        type="email"
        class="newsletter-form__input"
        id="newsletterEmail"
        placeholder="Tu correo electrónico"
        required
        aria-label="Correo electrónico"
      >
      <button type="submit" class="newsletter-form__btn">Suscribirse</button>
    </form>
    <p class="newsletter-disclaimer animate-on-scroll animate-on-scroll--delay-2">
      Sin spam. Cancela cuando quieras. <i class="fas fa-lock" style="font-size: 0.7em; margin-left: 0.25rem;"></i>
    </p>
  </div>
</section>