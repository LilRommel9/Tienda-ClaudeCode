{%- comment -%}
  ========================================
  CART PAGE - CARRITO DE COMPRAS
  ========================================
  Esta plantilla muestra el carrito y permite checkout.
  Incluye botón de checkout por WhatsApp.
  ========================================
-%}

<div class="cart-page py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="font-cinzel mb-0">Tu Carrito</h1>
      <span class="badge bg-primary" id="cartItemCount">{{ cart.item_count }} artículos</span>
    </div>

    {%- if cart.item_count > 0 -%}
    <div class="row">
      {%- comment -%} CART ITEMS {%- endcomment -%}
      <div class="col-lg-8">
        <div class="cart-items">
          {%- for item in cart.items -%}
          <div class="cart-item row g-3 align-items-center p-4 mb-3 rounded shadow-sm" style="background: rgba(255,255,255,0.05);" data-id="{{ item.id }}">
            <div class="col-2 col-md-1">
              <a href="{{ item.url }}">
                <img src="{{ item.image | img_url: '150x150' }}" alt="{{ item.title }}" class="img-fluid rounded" style="width: 60px; height: 60px; object-fit: cover;">
              </a>
            </div>
            <div class="col-4 col-md-5">
              <h5 class="mb-1">
                <a href="{{ item.url }}" class="text-white text-decoration-none">{{ item.product_title }}</a>
              </h5>
              {%- if item.variant_title != 'Default Title' -%}
              <small class="text-muted">{{ item.variant_title }}</small>
              {%- endif -%}
            </div>
            <div class="col-2 col-md-2 text-center">
              <span class="fw-bold">{{ item.price | money }}</span>
            </div>
            <div class="col-2 col-md-2 text-center">
              <div class="input-group">
                <button class="btn btn-outline-secondary btn-sm" type="button" onclick="updateCartQty({{ item.key }}, {{ item.quantity - 1 }})">-</button>
                <input type="number" class="form-control form-control-sm text-center" value="{{ item.quantity }}" min="1" max="99" onchange="updateCartQty({{ item.key }}, this.value)">
                <button class="btn btn-outline-secondary btn-sm" type="button" onclick="updateCartQty({{ item.key }}, {{ item.quantity + 1 }})">+</button>
              </div>
            </div>
            <div class="col-2 col-md-2 text-center">
              <span class="fw-bold text-warning">{{ item.line_price | money }}</span>
            </div>
            <div class="col-auto">
              <button class="btn btn-outline-danger btn-sm" onclick="removeFromCart({{ item.key }})">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
          {%- endfor -%}
        </div>

        {%- comment -%} CONTINUE SHOPPING {%- endcomment -%}
        <div class="text-start mt-4">
          <a href="/collections/all" class="btn btn-outline-light">
            <i class="fas fa-arrow-left me-2"></i>Seguir Comprando
          </a>
        </div>
      </div>

      {%- comment -%} CART SUMMARY {%- endcomment -%}
      <div class="col-lg-4">
        <div class="cart-summary p-4 rounded shadow" style="background: rgba(255,255,255,0.05); position: sticky; top: 100px;">
          <h3 class="font-cinzel mb-4">Resumen</h3>

          <div class="d-flex justify-content-between mb-2">
            <span>Subtotal</span>
            <span class="fw-bold">{{ cart.total_price | money }}</span>
          </div>

          <div class="d-flex justify-content-between mb-2">
            <span>Envío</span>
            <span class="fw-bold">
              {%- if cart.total_price >= settings.free_shipping_threshold -%}
              <span class="text-success">GRATIS</span>
              {%- else -%}
              Calcular en checkout
              {%- endif -%}
            </span>
          </div>

          <hr class="my-3">

          <div class="d-flex justify-content-between mb-3">
            <span class="h6">Total</span>
            <span class="h5 text-warning">{{ cart.total_price | money }}</span>
          </div>

          {%- if cart.total_price < settings.free_shipping_threshold -%}
          <div class="alert alert-info small mb-3">
            <i class="fas fa-info-circle me-2"></i>
            Agrega ${{ settings.free_shipping_threshold | minus: cart.total_price | money_without_currency }} MXN más para envío gratis
          </div>
          {%- endif -%}

          {%- comment -%} CHECKOUT BUTTONS {%- endcomment -%}
          <div class="d-grid gap-2">
            <a href="{{ shop.url }}/checkout" class="btn btn-primary btn-lg">
              <i class="fas fa-lock me-2"></i>Checkout Seguro
            </a>

            <button class="btn btn-success btn-lg" onclick="checkoutViaWhatsApp()">
              <i class="fab fa-whatsapp me-2"></i>Pedir por WhatsApp
            </button>

            <a href="/collections/all" class="btn btn-outline-light">
              <i class="fas fa-plus me-2"></i>Agregar más productos
            </a>
          </div>

          {%- comment -%} SECURITY BADGES {%- endcomment -%}
          <div class="text-center mt-4 pt-3 border-top">
            <small class="text-muted d-block">
              <i class="fas fa-shield-alt text-warning me-1"></i> Pago seguro
            </small>
            <small class="text-muted d-block">
              <i class="fas fa-truck text-warning me-1"></i> Envío {{ settings.shipping_days }} días
            </small>
            <small class="text-muted d-block">
              <i class="fas fa-undo text-warning me-1"></i> 30 días para devoluciones
            </small>
          </div>
        </div>
      </div>
    </div>
    {%- else -%}
    {%- comment -%} EMPTY CART {%- endcomment -%}
    <div class="text-center py-5">
      <i class="fas fa-shopping-cart fa-5x text-muted mb-4"></i>
      <h2 class="font-cinzel mb-3">Tu carrito está vacío</h2>
      <p class="text-white mb-4">Agrega algunos productos increíbles a tu carrito</p>
      <a href="/collections/all" class="btn btn-primary btn-lg">
        <i class="fas fa-gem me-2"></i>Explorar Productos
      </a>
    </div>
    {%- endif -%}
  </div>
</div>

<script>
  // Cart functionality
  function updateCartQty(key, qty) {
    if (qty < 1) {
      removeFromCart(key);
      return;
    }
    // En Shopify real, esto haría fetch a /cart/update.js
    console.log('Update quantity:', key, qty);
    // Recargar página para actualizar totales
    location.reload();
  }

  function removeFromCart(key) {
    // En Shopify real: fetch('/cart/change.js', { method: 'POST', body: JSON.stringify({ id: key, quantity: 0 }) })
    console.log('Remove item:', key);
    location.reload();
  }

  function checkoutViaWhatsApp() {
    let message = "Hola! Quiero hacer mi pedido en {{ settings.brand_name }}:\n\n";
    let total = 0;

    {%- for item in cart.items -%}
    message += "• {{ item.product_title }} {{ item.variant_title }} x{{ item.quantity }} - {{ item.line_price | money }}\n";
    {%- endfor -%}

    message += "\nTotal: {{ cart.total_price | money }}\n\n";
    message += "¿Me pueden guiar con el pago y envío?";

    window.open("https://wa.me/{{ settings.whatsapp_number }}?text=" + encodeURIComponent(message), '_blank');
  }
</script>