{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title",
          "settings": {
            "text_size": "h1",
            "title_alignment": "center",
            "uppercase_title": false,
            "margin_top": 0,
            "margin_bottom": 0
          }
        },
        "rating_stars": {
          "type": "rating_stars",
          "settings": {
            "rating": 4.8,
            "star_color": "#ffcc00",
            "bg_stars_style": "full",
            "bg_star_color": "#ececec",
            "label": "(2,847 Reseñas)",
            "size": 20,
            "alignment": "center",
            "margin_top": 8,
            "margin_bottom": 16
          }
        },
        "price": {
          "type": "price",
          "settings": {
            "layout": "price_first",
            "price_color": "accent-1",
            "compare_price_color": "text",
            "displayed_badge": "sale",
            "custom_badge_text": "[icon_1] 10% DE DESCUENTO HOY"
          }
        },
        "description": {
          "type": "description",
          "settings": {
            "margin_top": 24,
            "margin_bottom": 24
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": false,
            "skip_cart": false,
            "uppercase_text": true,
            "icon_scale": 120,
            "icon_spacing": 10,
            "enable_custom_color": true,
            "custom_color": "#6D388B",
            "margin_top": 24,
            "margin_bottom": 24
          }
        },
        "shipping_checkpoints": {
          "type": "shipping_checkpoints",
          "settings": {
            "icon_1": "add_shopping_cart",
            "top_text_1": "Ordenado",
            "bottom_text_1": "Hoy",
            "icon_2": "local_shipping",
            "top_text_2": "Listo",
            "bottom_text_2": "2-3 días",
            "icon_3": "redeem",
            "top_text_3": "Entregado",
            "bottom_text_3": "5-7 días",
            "color_scheme": "inverse",
            "margin_top": 24,
            "margin_bottom": 24
          }
        }
      },
      "block_order": ["title", "rating_stars", "price", "description", "buy_buttons", "shipping_checkpoints"],
      "settings": {
        "enable_sticky_info": true,
        "display_variant_image_first": false,
        "disable_prepend": true,
        "hide_variants": false,
        "variant_image_filtering": "none",
        "image_zoom": "none",
        "thumbnails_ratio": "square",
        "media_size": "large",
        "media_position": "left",
        "gallery_layout": "thumbnail_slider",
        "desktop_thumbnails_position": "bottom",
        "constrain_to_viewport": true,
        "media_fit": "contain"
      }
    },
    "benefits": {
      "type": "icon-bar",
      "blocks": {
        "b1": {
          "type": "column",
          "settings": {
            "icon": "shield",
            "title": "Seguridad garantizada",
            "text": "<p>Certificado médico y respaldado por profesionales.</p>"
          }
        },
        "b2": {
          "type": "column",
          "settings": {
            "icon": "check_circle",
            "title": "Fácil de usar",
            "text": "<p>Diseñado para personas mayores sin complicaciones.</p>"
          }
        },
        "b3": {
          "type": "column",
          "settings": {
            "icon": "support_agent",
            "title": "Soporte 24/7",
            "text": "<p>Atención en español, 7 días a la semana.</p>"
          }
        }
      },
      "block_order": ["b1", "b2", "b3"],
      "settings": {
        "visibility": "always-display",
        "title": "Beneficios clave",
        "title_highlight_color": "#6D388B",
        "heading_size": "h2",
        "color_scheme": "background-1"
      }
    },
    "testimonios": {
      "type": "testimonials",
      "blocks": {
        "t1": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "María G., 71 años",
            "text": "<p style='font-size:18px;'>\"Me siento más segura caminando por la casa. Mis hijos están aliviados.\"</p>",
            "author": "<em>María G.<\/em>"
          }
        },
        "t2": {
          "type": "column",
          "settings": {
            "star_rating": 5,
            "title": "Carlos M., hijo comprador",
            "text": "<p style='font-size:18px;'>\"Regalé esto a mi mamá y cambió su vida. Lo recomiendo 100%.\"</p>",
            "author": "<em>Carlos M.<\/em>"
          }
        }
      },
      "block_order": ["t1", "t2"],
      "settings": {
        "title": "Lo que dicen las familias",
        "title_highlight_color": "#6D388B",
        "heading_size": "h2",
        "color_scheme": "background-2",
        "show_stars": true,
        "star_color": "#ffcc00"
      }
    }
  },
  "order": ["main", "benefits", "testimonios"]
}